<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="rootPane" minHeight="600.0" minWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tr.com.yusufgunduz.httpclientfx.HelloController">

    <children>
        <TabPane layoutY="-1.0" tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
            <tabs>
                <Tab text="New Request">
                    <content>
                        <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                     <children>
                        <ComboBox fx:id="httpMethod" layoutX="10.0" layoutY="12.0" prefHeight="36.0" prefWidth="96.0" promptText="METHOD" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="12.0">
                           <items>
                              <FXCollections fx:factory="observableArrayList">
                                 <String fx:value="GET" />
                                 <String fx:value="POST" />
                                 <String fx:value="PUT" />
                                 <String fx:value="DELETE" />
                                 <String fx:value="PATCH" />
                              </FXCollections>
                           </items>
                        </ComboBox>
                        <TextField fx:id="url" layoutX="151.0" layoutY="12.0" prefHeight="36.0" prefWidth="522.0" text="http://www.epias.com.tr" AnchorPane.leftAnchor="120.0" AnchorPane.rightAnchor="107.0" AnchorPane.topAnchor="12.0" />
                        <Button fx:id="sendButton" mnemonicParsing="false" onAction="#onSendButtonClick" prefHeight="36.0" prefWidth="85.0" text="SEND" wrapText="true" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="12.0" />
                        <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#onCancelButtonClick" prefHeight="36.0" prefWidth="85.0" text="CANCEL" visible="false" wrapText="true" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="12.0" />
                     </children>
                     <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </padding></AnchorPane>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </children>

    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
</AnchorPane>

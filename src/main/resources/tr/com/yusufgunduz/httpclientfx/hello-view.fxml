<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="rootPane" minHeight="600.0" minWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tr.com.yusufgunduz.httpclientfx.HelloController">
    <children>
      <Group layoutX="9.0" layoutY="14.0">
         <children>
              <Button fx:id="sendButton" layoutX="702.0" mnemonicParsing="false" onAction="#onSendButtonClick" prefHeight="47.0" prefWidth="85.0" text="SEND" wrapText="true" />
              <ComboBox fx:id="httpMethod" layoutY="2.0" prefHeight="39.0" prefWidth="130.0" promptText="HTTP METHOD">
                  <items>
                      <FXCollections fx:factory="observableArrayList">
                          <String fx:value="GET" />
                          <String fx:value="POST" />
                          <String fx:value="PUT" />
                          <String fx:value="DELETE" />
                          <String fx:value="PATCH" />
                      </FXCollections>
                  </items>
              </ComboBox>
              <TextField fx:id="url" layoutX="141.0" layoutY="4.0" prefHeight="38.0" prefWidth="550.0" />
         </children>
      </Group>
      <Group layoutX="14.0" layoutY="70.0">
         <children>
            <CheckBox fx:id="sslCheckBox" mnemonicParsing="false" selected="true" text="SSL certificate verification" />
            <CheckBox fx:id="followRedirectCheckBox" layoutX="165.0" mnemonicParsing="false" selected="true" text="Follow Redirects" />
         </children>
      </Group>
      <Group layoutX="10.0" layoutY="106.0">
         <children>
            <TextArea fx:id="requestHeaderTextarea" layoutY="19.0" prefHeight="200.0" prefWidth="330.0" />
            <Label text="Request Headers" />
            <Group layoutX="450.0">
               <children>
                  <TextArea fx:id="responseHeaderTextarea" editable="false" layoutX="5.0" layoutY="19.0" prefHeight="200.0" prefWidth="330.0" />
                  <Label layoutX="5.0" text="Response Headers" />
               </children>
            </Group>
         </children>
      </Group>
    </children>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tr.com.yusufgunduz.httpclientfx.RequestTabController"
            minWidth="800.0" minHeight="600.0">

    <children>
        <ComboBox fx:id="httpMethod"
                  prefWidth="120.0"
                  AnchorPane.topAnchor="10.0"
                  AnchorPane.leftAnchor="10.0"/>

        <TextField fx:id="urlField"
                   promptText="https://example.com"
                   AnchorPane.topAnchor="10.0"
                   AnchorPane.leftAnchor="140.0"
                   AnchorPane.rightAnchor="190.0"/>

        <Button fx:id="sendButton"
                text="Send"
                onAction="#onSend"
                AnchorPane.topAnchor="10.0"
                AnchorPane.rightAnchor="100.0"/>

        <Button fx:id="cancelButton"
                text="Cancel"
                visible="false"
                onAction="#onCancel"
                AnchorPane.topAnchor="10.0"
                AnchorPane.rightAnchor="10.0"/>

        <TextArea fx:id="responseBodyArea"
                  editable="false"
                  AnchorPane.topAnchor="60.0"
                  AnchorPane.leftAnchor="10.0"
                  AnchorPane.rightAnchor="10.0"
                  AnchorPane.bottomAnchor="10.0"/>
    </children>
</AnchorPane>